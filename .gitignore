.vscode/
.vs/
*.suo
*.user
*.VC.db
*.VC.VC.opendb

# Local debug outputs, reports, and temporary logs.
*_out*.txt
*_output.txt
*.log
*.tmp
*.temp
weekly_report_*.md

# Python helper script caches.
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local environment files. Keep only explicit examples.
.env
.env.*
!.env.example

# Operating system noise.
.DS_Store
Thumbs.db
desktop.ini

