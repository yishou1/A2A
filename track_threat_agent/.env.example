NACOS_ENABLED=false
NACOS_SERVER=127.0.0.1:8848
NACOS_NAMESPACE=public
NACOS_GROUP=DEFAULT_GROUP

# Use A2A-Agent when integrating with the shared A2A repository.
SERVICE_NAME=A2A-Agent
SERVICE_IP=127.0.0.1
SERVICE_PORT=8102
AGENT_ID=track-threat-group-agent-01
AGENT_ROLE=track_threat
AGENT_STATUS=idle
HEARTBEAT_INTERVAL=5

# The Agent owns its long-lived TrackStore. When enabled, shared M03-M07
# algorithm services are preferred for feature fusion, type completion,
# association verification, trajectory prediction, and graph relations.
# Every remote step has a local continuity fallback.
ALGORITHM_PROVIDER=algorithm_library_preferred
ALGORITHM_LIBRARY_ENABLED=false
ALGORITHM_LIBRARY_SERVICE_NAME=track-threat-algorithms
# Optional local override. Empty means discover through Nacos.
ALGORITHM_LIBRARY_BASE_URL=
ALGORITHM_LIBRARY_TIMEOUT_S=3
ALGORITHM_LIBRARY_REFRESH_S=30

# Optional local restart snapshot. Defaults to:
# ../.a2a_state/track_threat_agent_state.json when running from this repo.
TRACK_THREAT_STATE_PATH=

# Optional trained ST-GNN v2 TorchScript bundles. The Agent will use the
# built-in models/track_threat bundles when these values are empty. Install
# requirements-model.txt on a host that enables TorchScript CPU inference.
ST_GNN_AIRCRAFT_MODEL_DIR=
ST_GNN_SHIP_MODEL_DIR=
# Backward-compatible single-model entry (treated as aircraft):
ST_GNN_MODEL_DIR=
ST_GNN_REQUIRED=false
ST_GNN_MAX_INFERENCE_MS=200
