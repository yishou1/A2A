# 战术情报 Agent（复制为 .env 后按需修改）
PYTHONPATH=.

# 推理配置：config/default.yaml（真实）或 config/mock.yaml（轻量）
TIA_CONFIG=config/default.yaml

# 服务端口（8015 可能与 evaluator 冲突，联调建议 8016）
TIA_PORT=8016
TIA_NACOS_REGISTER=0

# Nacos（remote 模式联调时设为 1）
# TIA_NACOS_REGISTER=1
# NACOS_ADDR=127.0.0.1:8848

# SynapseRAG（default.yaml 中 llm_model 使用 OpenAI 时需要）
# OPENAI_API_KEY=sk-...
